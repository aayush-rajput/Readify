# ============================================
# Readify LMS — Environment Variables
# ============================================

# Frontend (Vite) — these go in the project root .env
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ============================================
# Supabase Project Details (for reference)
# ============================================
# SUPABASE_PROJECT_ID=your-project-id
# SUPABASE_DB_HOST=db.your-project-id.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-database-password

# ============================================
# Optional: Service Role Key (for admin operations)
# WARNING: Never expose this in frontend code
# ============================================
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
